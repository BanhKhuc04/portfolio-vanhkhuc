generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Project {
  id            String   @id @default(uuid())
  titleEn       String
  titleVi       String
  descriptionEn String
  descriptionVi String
  imageUrl      String?
  githubUrl     String?
  liveUrl       String?
  tags          String[]
  featured      Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([featured])
}

model Skill {
  id        String   @id @default(uuid())
  name      String
  icon      String?
  category  String
  level     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
}

model Experience {
  id            String    @id @default(uuid())
  titleEn       String
  titleVi       String
  company       String
  descriptionEn String
  descriptionVi String
  startDate     DateTime
  endDate       DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model BlogPost {
  id          String    @id @default(uuid())
  slug        String    @unique
  titleEn     String
  titleVi     String
  summaryEn   String
  summaryVi   String
  contentEn   String
  contentVi   String
  published   Boolean   @default(false)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  imageUrl    String?

  @@index([published])
}

model SEOMetadata {
  id            String   @id @default(uuid())
  page          String   @unique
  titleEn       String
  titleVi       String
  descriptionEn String
  descriptionVi String
  keywords      String[]
  ogImage       String?
  updatedAt     DateTime @updatedAt
}

model ThemeConfig {
  id           String   @id @default(uuid())
  primaryColor String   @default("oklch(0.5 0.2 260)")
  radius       String   @default("0.75rem")
  updatedAt    DateTime @updatedAt
}

model ChatSession {
  id        String        @id @default(uuid())
  createdAt DateTime      @default(now())
  messages  ChatMessage[]
}

model ChatMessage {
  id        String      @id @default(uuid())
  sessionId String
  role      String
  content   String
  createdAt DateTime    @default(now())
  session   ChatSession @relation(fields: [sessionId], references: [id])

  @@index([sessionId])
}

model AIPrompt {
  id        String   @id @default(uuid())
  content   String
  updatedAt DateTime @updatedAt
}

model ShortLink {
  id          String          @id @default(uuid())
  originalUrl String
  shortCode   String          @unique
  clicks      Int             @default(0)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  analytics   LinkAnalytics[]

  @@index([shortCode])
}

model LinkAnalytics {
  id        String    @id @default(uuid())
  linkId    String
  userAgent String?
  ipHash    String?
  createdAt DateTime  @default(now())
  link      ShortLink @relation(fields: [linkId], references: [id])

  @@index([linkId])
}

model ActivityLog {
  id        String   @id @default(uuid())
  action    String
  target    String
  details   String?
  createdAt DateTime @default(now())

  @@index([createdAt])
}
